# =========================

# ROOT .gitignore (Fullstack)

# =========================

# ---- Dependencies ----

node_modules/
client/node_modules/
server/node_modules/

# ---- Environment variables ----

.env
.env.*
client/.env
client/.env.*
server/.env
server/.env.*

# ---- Logs ----

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Build output ----

dist/
build/
client/build/
client/dist/
server/build/
server/dist/

# ---- OS files ----

.DS_Store
Thumbs.db

# ---- Editor / IDE ----

.vscode/
.idea/
*.swp
*.swo

# ---- Uploads / user files ----

server/uploads/
uploads/

# ---- Cache ----

.cache/
.tmp/
temp/

# ---- Coverage ----

coverage/

# ---- Package manager lock files (optional) ----

# Keep ONE of these depending on your setup

# package-lock.json

# yarn.lock

# pnpm-lock.yaml

# ---- Misc ----

*.pid
*.seed
*.pid.lock

# ---- Claude / AI tooling (optional) ----

.claude/

# ---- Local config ----

*.local.json

# ---- Terraform ----
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup

# ---- Lambda build artifacts ----
infra/lambdas/game/node_modules/
infra/lambdas/upload/node_modules/
infra/modules/lambda/*.zip
